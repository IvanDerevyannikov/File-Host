app:
  name: FileServer
  version: 1.0.0
server:
  host: localhost
  port: 8080
directory:
  static: ../src/static
  js: ../src/static/js
  html_templates: ../src/static/html_templates
  image: ../src/static/image
  css: ../src/static/css
  storage: ../storage
  bin: ./
  tmp: ../tmp
err:
  main:
    full: close