app:
  name: FileServer
  version: 1.0.0
server:
  host: localhost
  port: 8080
directory:
  static: ../src/static
  js: ../src/static/js
  html_templates: ../src/static/html_templates
  image: ../src/static/image
  css: ../src/static/css
  locales: ../src/static/locales
  storage: ../storage
  bin: ./
  tmp: ../tmp
settings:
  maxFileSize: 100
  alowedFiles: ["PDF", "JSON", "TXT", "XML", "DOC", "MP3", "MP4"]
  language: en
  theme: dark
  buccet:
    life: true
    buccetLife: 24
  hiddenFiles:
    exicted: true
    show: true  
  folderDepth: 5
  users:
    canDelete: false
    canAdd: false
    canModifided: false
err:
  main:
    full: close